# Identity used by polite scholarly APIs (never a publisher/library password)
DOI2PDF_CONTACT_EMAIL=you@example.org
UNPAYWALL_EMAIL=you@example.org
DOI2PDF_SETUP_COMPLETE=false
DOWNLOAD_DIR=downloads

# Optional metadata/OA API keys
PUBMED_API_KEY=
S2_API_KEY=

# Optional, official publisher text-and-data-mining credentials
ELSEVIER_TDM_KEY=
ELSEVIER_INSTTOKEN=
WILEY_TDM_TOKEN=
SPRINGER_API_KEY=

# Zotero translation-server (run separately; default shown)
DOI2PDF_TRANSLATOR_ENABLED=true
ZOTERO_TRANSLATION_SERVER=http://127.0.0.1:1969

# Use only the prefix issued for your own institution. OpenAthens prefixes end in ?url=
OPENATHENS_REDIRECTOR_PREFIX=
# Examples supported: https://login.example.edu/login?url= or a template containing {url}/{doi}
EZPROXY_PREFIX=
# SFX/OpenURL template, for example https://resolver.example.edu/openurl?doi={doi}
LIBRARY_RESOLVER_TEMPLATE=

# Persistent Playwright profile; visible browser is the safe default for SSO/MFA
DOI2PDF_BROWSER_PROFILE=./doi2pdf-browser
DOI2PDF_BROWSER_HEADLESS=false

# Institutional safeguards. The code enforces >=15 seconds and <=100 requests/day.
DOI2PDF_INSTITUTION_INTERVAL_S=15
DOI2PDF_MAX_INSTITUTION_REQUESTS_PER_DAY=100
DOI2PDF_REQUEST_TIMEOUT_S=45
