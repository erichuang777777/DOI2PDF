# Identity used by polite scholarly APIs (never a publisher/library password)
DOI2PDF_CONTACT_EMAIL=you@example.org
UNPAYWALL_EMAIL=you@example.org
DOI2PDF_SETUP_COMPLETE=false
DOWNLOAD_DIR=downloads

# Optional metadata/OA API keys
PUBMED_API_KEY=
S2_API_KEY=
CORE_API_KEY=

# Optional, official publisher text-and-data-mining credentials
ELSEVIER_TDM_KEY=
ELSEVIER_INSTTOKEN=
WILEY_TDM_TOKEN=
SPRINGER_API_KEY=

# Zotero translation-server (run separately; default shown)
DOI2PDF_TRANSLATOR_ENABLED=true
ZOTERO_TRANSLATION_SERVER=http://127.0.0.1:1969

# Use only the prefix issued for your own institution. OpenAthens prefixes end in ?url=
# auto checks DOI2PDF_CAMPUS_CIDRS; off_campus permits OpenAthens only; campus permits direct/EZproxy routes.
DOI2PDF_NETWORK_MODE=auto
# Optional comma-separated campus ranges used by auto mode, e.g. 140.112.0.0/16
DOI2PDF_CAMPUS_CIDRS=
OPENATHENS_REDIRECTOR_PREFIX=
# Examples supported: https://login.example.edu/login?url= or a template containing {url}/{doi}
EZPROXY_PREFIX=
# Optional suffix for publisher-specific proxy hosts, e.g. ezproxy.example.edu
EZPROXY_SUFFIX=
# SFX/OpenURL template, for example https://resolver.example.edu/openurl?doi={doi}
LIBRARY_RESOLVER_TEMPLATE=

# Optional read-only SQLite sources inherited from paper-fetch
PAPER_RADAR_DB=
HOLDINGS_DB=

# Optional plain EZproxy/NetScaler form login. Keep passwords local and ignored.
# OpenAthens/Shibboleth/CAPTCHA/MFA should be completed in visible Chromium instead.
LIBRARY_LOGIN_URL=
LIBRARY_USERNAME=
LIBRARY_PASSWORD=
LIBRARY_USER_SELECTOR=input[name='user'],#id_username
LIBRARY_PASSWORD_SELECTOR=input[name='pass'],#id_password
LIBRARY_SUBMIT_SELECTOR=form button[type='submit'],form input[type='submit']

# Persistent Playwright profile; visible browser is the safe default for SSO/MFA
DOI2PDF_BROWSER_PROFILE=./doi2pdf-browser
DOI2PDF_BROWSER_HEADLESS=false
# Institutional safeguards. The code enforces >=15 seconds and <=100 requests/day.
DOI2PDF_INSTITUTION_INTERVAL_S=15
DOI2PDF_MAX_INSTITUTION_REQUESTS_PER_DAY=100
DOI2PDF_REQUEST_TIMEOUT_S=45
DOI2PDF_HTTP_MAX_RETRIES=3

# Optional LLM-assisted final-link ranking. Candidate query strings and page secrets are never sent.
# Supports an HTTPS OpenAI-compatible endpoint or loopback HTTP (for example Ollama).
DOI2PDF_LLM_ENABLED=false
DOI2PDF_LLM_BASE_URL=
DOI2PDF_LLM_MODEL=
DOI2PDF_LLM_API_KEY=
